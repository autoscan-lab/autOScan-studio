{
  "compilerOptions": {
    "composite": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "outDir": "./out",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "electron"],
  },
  "include": ["src/main/**/*", "src/preload/**/*", "electron.vite.config.ts"],
}
